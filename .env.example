# Public API base URL (browser calls this directly — must match CORS on the backend).
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Optional: when the marketing site is deployed alone (e.g. Vercel) and the signed-in app
# is deployed elsewhere, set this to that app’s origin (no trailing slash). Sign-in links
# and /login redirect to https://YOUR_APP_ORIGIN/login. Omit for local / single Next app.
# NEXT_PUBLIC_APP_ORIGIN=https://app.yourdomain.com
